# DOPEHOUSE OPENMIC - Environment Configuration
# Created by Jacob Daniel Powell
#
# Get your API token from https://platform.acedata.cloud

# AceDataCloud API Configuration (REQUIRED)
ACEDATACLOUD_API_TOKEN=your_api_token_here
ACEDATACLOUD_API_BASE_URL=https://api.acedata.cloud

# Suno Configuration (Optional)
SUNO_DEFAULT_MODEL=chirp-v5-5
SUNO_REQUEST_TIMEOUT=1800

# MCP Server Configuration (Optional)
MCP_SERVER_NAME=dopehouse-openmic
MCP_TRANSPORT=stdio

# Logging (Optional)
LOG_LEVEL=INFO
